---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#" class="brand">
      <img src="/logo.png" alt="contamovil logo" class="logo-img" />
      <span class="brand-text">contamovil</span>
    </a>
    <div class="nav-links">
      <a href="#modulos">Módulos</a>
      <a href="#beneficios">Beneficios</a>
      <a href="#precios">Precios</a>
      <a href="#contacto">Contacto</a>
    </div>
    <a href="https://wa.me/51958250742?text=Hola,%20quiero%20empezar%20mi%20mes%20gratis%20con%20contamovil" target="_blank" class="btn-nav">
      Empezar ahora
    </a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-glow glow-1"></div>
    <div class="hero-glow glow-2"></div>
    <div class="hero-glow glow-3"></div>
    <div class="hero-grid"></div>
  </div>
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Hecho para el comerciante peruano 🇵🇪
    </div>
    <h1 class="hero-title">
      Controla tu negocio,<br/>
      <em>vende más,</em><br/>
      pierde menos.
    </h1>
    <p class="hero-sub">
      La app que tu tienda necesita para dejar de perder dinero por falta de control.
      Sencilla, rápida y diseñada para el día a día.
    </p>
    <div class="hero-ctas">
      <a href="https://wa.me/51958250742?text=Hola,%20quiero%20empezar%20mi%20mes%20gratis%20con%20contamovil" target="_blank" class="btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.853L.057 23.5l5.806-1.452A11.956 11.956 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.013-1.376l-.36-.214-3.726.931.99-3.617-.235-.373A9.818 9.818 0 1 1 12 21.818z"/></svg>
        Empezar gratis por WhatsApp
      </a>
      <a href="#precios" class="btn-ghost">Ver precios →</a>
    </div>
    <div class="hero-stats">
      <div class="stat"><strong>3</strong><span>Módulos</span></div>
      <div class="stat-div"></div>
      <div class="stat"><strong>60%</strong><span>Descuento</span></div>
      <div class="stat-div"></div>
      <div class="stat"><strong>5 min</strong><span>Para empezar</span></div>
    </div>
  </div>
  <div class="hero-cards">
    <div class="float-card">
      <div class="fc-icon">📦</div>
      <div class="fc-text"><span class="fc-label">Stock actual</span><span class="fc-value">42 productos</span></div>
      <div class="fc-badge green">En control</div>
    </div>
    <div class="float-card fc-offset">
      <div class="fc-icon">🧾</div>
      <div class="fc-text"><span class="fc-label">Última venta</span><span class="fc-value">S/ 65.97</span></div>
      <div class="fc-badge purple">Registrada</div>
    </div>
    <div class="float-card">
      <div class="fc-icon">📊</div>
      <div class="fc-text"><span class="fc-label">Ganancia del mes</span><span class="fc-value">S/ 2,840</span></div>
      <div class="fc-badge blue">PDF listo</div>
    </div>
  </div>
</section>

<!-- MÓDULOS -->
<section class="modulos" id="modulos">
  <div class="container">
    <div class="section-label">Los 3 módulos</div>
    <h2 class="section-title">Todo lo que necesita tu tienda, <span>en un solo lugar</span></h2>
    <p class="section-sub">Cada módulo fue diseñado pensando en cómo trabaja una persona real detrás de un mostrador.</p>
    <div class="modulos-grid">

      <div class="modulo-card mod-dark">
        <div class="mod-number">01</div>
        <div class="mod-icon-wrap"><span>🧾</span></div>
        <h3>Punto de Venta</h3>
        <p class="mod-desc">Registra cada venta de forma completa y sin errores en segundos.</p>
        <ul class="mod-list">
          <li><span class="check ck-green">✓</span> Agrega productos al carrito con un toque</li>
          <li><span class="check ck-green">✓</span> Aplica descuentos personalizados por venta</li>
          <li><span class="check ck-green">✓</span> Registra toda la info: cliente, productos, total y fecha</li>
          <li><span class="check ck-green">✓</span> Historial completo guardado automáticamente</li>
          <li><span class="check ck-green">✓</span> Envía recibos por WhatsApp al instante</li>
        </ul>
        <div class="mod-benefit ben-green">→ Nunca más pierdas el control de lo que vendes ni cuánto cobras</div>
      </div>

      <div class="modulo-card mod-light">
        <div class="mod-number mod-num-dark">02</div>
        <div class="mod-icon-wrap mod-ico-purple"><span>📦</span></div>
        <h3 class="h3-dark">Control de Stock</h3>
        <p class="mod-desc mod-desc-dark">Sabe exactamente qué tienes, cuánto queda y qué necesitas reponer.</p>
        <ul class="mod-list mod-list-dark">
          <li><span class="check ck-purple">✓</span> Stock en tiempo real por producto y categoría</li>
          <li><span class="check ck-purple">✓</span> Alertas automáticas de stock mínimo</li>
          <li><span class="check ck-purple">✓</span> Unidades flexibles: kg, litros, metros, cajas y más</li>
          <li><span class="check ck-purple">✓</span> Organización por categorías con íconos y colores</li>
          <li><span class="check ck-purple">✓</span> El stock baja solo con cada venta registrada</li>
        </ul>
        <div class="mod-benefit ben-purple">→ Elimina las pérdidas por productos agotados o exceso de compra</div>
      </div>

      <div class="modulo-card mod-purple">
        <div class="mod-number mod-num-white">03</div>
        <div class="mod-icon-wrap mod-ico-white"><span>📊</span></div>
        <h3>Reportes e Historial</h3>
        <p class="mod-desc mod-desc-white">Toma decisiones con datos reales de tu negocio, no con suposiciones.</p>
        <ul class="mod-list mod-list-white">
          <li><span class="check ck-white">✓</span> Historial de ventas por día con filtro de calendario</li>
          <li><span class="check ck-white">✓</span> Reportes PDF con filtros de fecha y categoría</li>
          <li><span class="check ck-white">✓</span> Top productos más vendidos y más rentables</li>
          <li><span class="check ck-white">✓</span> Resumen de ganancias netas listo para compartir</li>
          <li><span class="check ck-white">✓</span> Gestión de clientes con nombre y teléfono</li>
        </ul>
        <div class="mod-benefit ben-white">→ Conoce tus números sin necesitar un contador</div>
      </div>

    </div>
  </div>
</section>

<!-- BENEFICIOS -->
<section class="beneficios" id="beneficios">
  <div class="container">
    <div class="section-label">¿Por qué contamovil?</div>
    <h2 class="section-title">Tu tienda merece más que <span>un cuaderno y la memoria</span></h2>
    <div class="benefits-grid">
      <div class="benefit-item"><div class="benefit-icon">⚡</div><div class="benefit-text"><h4>Sin curva de aprendizaje</h4><p>Si usas WhatsApp, puedes usar contamovil. Empieza a operar el mismo día, sin manuales ni capacitaciones.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">☁️</div><div class="benefit-text"><h4>Datos en la nube</h4><p>Accede desde cualquier celular sin perder información. Tu negocio siempre contigo, en cualquier lugar.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">📉</div><div class="benefit-text"><h4>Cero pérdidas por descontrol</h4><p>El stock baja automáticamente con cada venta. Nunca más productos agotados sin que te des cuenta.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">🧠</div><div class="benefit-text"><h4>Decisiones inteligentes</h4><p>Sabe qué productos te dan más ganancia y cuándo conviene comprar más stock.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">🤝</div><div class="benefit-text"><h4>Clientes fidelizados</h4><p>Registra tus clientes y envíales recibos por WhatsApp. Profesionalismo que genera confianza.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">📱</div><div class="benefit-text"><h4>Solo necesitas tu celular</h4><p>Disponible para iOS y Android. Sin computadora, sin equipo especial. App nativa y rápida.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">💬</div><div class="benefit-text"><h4>Soporte directo</h4><p>Resolvemos tus dudas por WhatsApp el mismo día. Soporte humano, no robots ni tickets interminables.</p></div></div>
      <div class="benefit-item"><div class="benefit-icon">🔓</div><div class="benefit-text"><h4>Sin contratos ni costos ocultos</h4><p>Paga solo si quieres continuar. Sin letra chica, sin sorpresas. Tú decides cada mes.</p></div></div>
    </div>
  </div>
</section>

<!-- PRECIOS -->
<section class="precios" id="precios">
  <div class="container">
    <div class="section-label light-label">Precios</div>
    <h2 class="section-title white-title">Oferta de <span class="span-light">lanzamiento</span></h2>
    <p class="section-sub white-sub">Empieza sin riesgo. Un mes para comprobar que funciona.</p>
    <div class="precios-wrap">
      <div class="precio-card">
        <div class="precio-badge">🔥 Oferta especial</div>
        <div class="precio-top">
          <div class="precio-regular">
            <span class="precio-label">Precio regular</span>
            <span class="precio-tachado">S/ 59.90<small>/mes</small></span>
          </div>
          <div class="precio-oferta">
            <span class="precio-descuento">60% OFF</span>
            <span class="precio-actual">S/ 23.96</span>
            <span class="precio-periodo">primer mes</span>
          </div>
        </div>
        <div class="precio-divider"></div>
        <ul class="precio-includes">
          <li><span class="pi-check">✓</span> Acceso completo a los 3 módulos</li>
          <li><span class="pi-check">✓</span> Onboarding (puesta en marcha) <strong>GRATUITO</strong></li>
          <li><span class="pi-check">✓</span> Soporte directo por WhatsApp incluido</li>
          <li><span class="pi-check">✓</span> Sin tarjeta, sin compromiso</li>
          <li><span class="pi-check">✓</span> Cuenta lista en menos de 5 minutos</li>
        </ul>
        <a href="https://wa.me/51958250742?text=Hola,%20quiero%20el%2060%25%20de%20descuento" target="_blank" class="btn-precio">
          Quiero el 60% de descuento →
        </a>
        <p class="precio-nota">Después del primer mes: S/ 59.90/mes. Cancela cuando quieras.</p>
      </div>
      <div class="onboarding-card">
        <h3>Puesta en marcha gratuita</h3>
        <p class="ob-intro">Cuando te unes, nosotros configuramos todo. Tú solo empiezas a vender.</p>
        <div class="onboarding-steps">
          <div class="ob-step">
            <div class="ob-num">1</div>
            <div class="ob-content"><h4>Generación de credenciales</h4><p>Creamos tu cuenta y configuramos tu tienda en menos de 5 minutos. Sin formularios largos.</p></div>
          </div>
          <div class="ob-connector"></div>
          <div class="ob-step">
            <div class="ob-num">2</div>
            <div class="ob-content"><h4>Registro de contamovil</h4><p>Te ayudamos a cargar todos tus productos, categorías y precios. Tu contamovil listo desde el primer día.</p></div>
          </div>
          <div class="ob-connector"></div>
          <div class="ob-step">
            <div class="ob-num">3</div>
            <div class="ob-content"><h4>Ingreso al sistema de ayuda</h4><p>Te integramos al sistema de atención: tutoriales, soporte por WhatsApp y todo lo que necesitas.</p></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACTO -->
<section class="contacto" id="contacto">
  <div class="container">
    <div class="cta-box">
      <div class="cta-glow"></div>
      <div class="cta-content">
        <h2>¿Listo para tomar el control de tu negocio?</h2>
        <p>Escríbenos y en menos de 5 minutos tienes tu cuenta lista. Sin tarjeta, sin compromiso.</p>
        <div class="cta-btns">
          <a href="https://wa.me/51958250742?text=Hola,%20quiero%20empezar%20mi%20mes%20con%20contamovil" target="_blank" class="btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.853L.057 23.5l5.806-1.452A11.956 11.956 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.013-1.376l-.36-.214-3.726.931.99-3.617-.235-.373A9.818 9.818 0 1 1 12 21.818z"/></svg>
            Empezar por WhatsApp
          </a>
          <a href="mailto:zuniganoriegadenzel@gmail.com" class="btn-ghost-dark">Enviar un email</a>
        </div>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/logo.png" alt="contamovil logo" class="logo-img logo-img-sm" />
      <div><strong>contamovil</strong><span>Sistema de gestión de ventas</span></div>
    </div>
    <div class="footer-contacts">
      <a href="https://wa.me/51958250742" target="_blank">📲 958 250 742</a>
      <a href="https://instagram.com/contamovil.pe" target="_blank">📸 @contamovil.pe</a>
      <a href="mailto:zuniganoriegadenzel@gmail.com">✉️ zuniganoriegadenzel@gmail.com</a>
    </div>
    <div class="footer-copy">© 2026 contamovil · Desarrollado para comerciantes peruanos 🇵🇪</div>
  </div>
</footer>

</Layout>

<style>
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(10,10,15,0.88); backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(91,75,219,0.2);
}
.nav-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; gap: 1.5rem; padding: 0.85rem 1.25rem;
}
.brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; }
.logo-img {
  width: 38px; height: 38px; border-radius: 50%;
  object-fit: cover; flex-shrink: 0;
}
.logo-img-sm { width: 30px; height: 30px; }
.brand-text { color: white; font-family: 'Sora', sans-serif; font-weight: 700; font-size: 1.05rem; }
.nav-links { display: flex; gap: 1.8rem; margin-left: auto; }
.nav-links a { color: var(--gray-400); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
.nav-links a:hover { color: white; }
.btn-nav { background: var(--purple); color: white; padding: 0.48rem 1.1rem; border-radius: 99px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; white-space: nowrap; }
.btn-nav:hover { background: var(--purple-light); transform: translateY(-1px); }

.hero {
  min-height: 100vh; background: var(--dark);
  display: flex; align-items: center;
  position: relative; overflow: hidden; padding: 7rem 1.25rem 4rem;
}
.hero-bg { position: absolute; inset: 0; pointer-events: none; }
.hero-glow { position: absolute; border-radius: 50%; filter: blur(80px); }
.glow-1 { width: 500px; height: 500px; background: var(--purple); top: -100px; left: -100px; opacity: 0.22; }
.glow-2 { width: 400px; height: 400px; background: #3D2EC4; bottom: 0; right: 10%; opacity: 0.18; }
.glow-3 { width: 300px; height: 300px; background: #7B6EE8; top: 40%; left: 40%; opacity: 0.1; }
.hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(91,75,219,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(91,75,219,.06) 1px,transparent 1px); background-size: 60px 60px; }
.hero-inner { max-width: 680px; position: relative; z-index: 2; margin: 0 auto 0 max(1.25rem, calc(50vw - 580px)); }
.hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(91,75,219,.2); border: 1px solid rgba(91,75,219,.4); color: var(--purple-mid); padding: 0.38rem 0.9rem; border-radius: 99px; font-size: 0.82rem; font-weight: 500; margin-bottom: 1.6rem; animation: fadeUp 0.6s ease both; }
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px #22c55e; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
@keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
.hero-title { font-size: clamp(2.2rem,5vw,3.8rem); font-weight: 800; color: white; line-height: 1.1; margin-bottom: 1.3rem; animation: fadeUp 0.6s .1s ease both; }
.hero-title em { font-style: normal; color: var(--purple-light); }
.hero-sub { font-size: 1rem; color: var(--gray-400); line-height: 1.75; margin-bottom: 2rem; animation: fadeUp 0.6s .2s ease both; }
.hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; animation: fadeUp 0.6s .3s ease both; }
.btn-primary { display: inline-flex; align-items: center; gap: 0.55rem; background: var(--purple); color: white; padding: 0.82rem 1.6rem; border-radius: 99px; text-decoration: none; font-weight: 700; font-size: 0.95rem; transition: all 0.2s; box-shadow: 0 0 28px rgba(91,75,219,.4); }
.btn-primary:hover { background: var(--purple-light); transform: translateY(-2px); }
.btn-ghost { display: inline-flex; align-items: center; color: var(--gray-400); text-decoration: none; padding: 0.82rem 1.4rem; border-radius: 99px; border: 1px solid rgba(255,255,255,.12); font-weight: 500; transition: all 0.2s; }
.btn-ghost:hover { color: white; border-color: rgba(255,255,255,.3); }
.hero-stats { display: flex; align-items: center; gap: 1.8rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,.08); animation: fadeUp 0.6s .4s ease both; }
.stat { display: flex; flex-direction: column; }
.stat strong { font-family: 'Sora', sans-serif; font-size: 1.7rem; font-weight: 800; color: white; }
.stat span { font-size: 0.75rem; color: var(--gray-400); }
.stat-div { width: 1px; height: 36px; background: rgba(255,255,255,.1); }
.hero-cards { position: absolute; right: max(2rem, calc(50vw - 580px)); top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 1rem; z-index: 2; animation: fadeUp 0.6s .5s ease both; }
.float-card { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); backdrop-filter: blur(20px); border-radius: var(--radius); padding: 1rem 1.1rem; display: flex; align-items: center; gap: 0.75rem; min-width: 210px; }
.fc-offset { margin-left: 1.5rem; }
.fc-icon { font-size: 1.4rem; }
.fc-text { display: flex; flex-direction: column; flex: 1; }
.fc-label { font-size: 0.7rem; color: var(--gray-400); }
.fc-value { font-family: 'Sora', sans-serif; font-weight: 700; color: white; font-size: 0.95rem; }
.fc-badge { font-size: 0.68rem; font-weight: 600; padding: 0.18rem 0.55rem; border-radius: 99px; }
.fc-badge.green { background: rgba(34,197,94,.15); color: #4ade80; }
.fc-badge.purple { background: rgba(91,75,219,.2); color: var(--purple-mid); }
.fc-badge.blue { background: rgba(59,130,246,.15); color: #93c5fd; }

.container { max-width: 1200px; margin: 0 auto; padding: 0 1.25rem; }
.section-label { display: inline-block; background: var(--purple-xlight); color: var(--purple); font-size: 0.75rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: 0.32rem 0.85rem; border-radius: 99px; margin-bottom: 1rem; }
.light-label { background: rgba(255,255,255,.1); color: white; }
.section-title { font-size: clamp(1.6rem,4vw,2.7rem); font-weight: 800; line-height: 1.2; margin-bottom: 0.9rem; color: var(--text); }
.section-title span { color: var(--purple); }
.white-title { color: white; }
.span-light { color: var(--purple-mid); }
.section-sub { font-size: 1rem; color: var(--gray-600); max-width: 540px; line-height: 1.72; margin-bottom: 3rem; }
